# ============================================================
# .env.example — Configuration template
# ✅ This file IS committed to Git (no secrets here)
# ❌ Copy to .env for local use — .env is gitignored
#
# cp .env.example .env
# ============================================================

# PostgreSQL connection string (SQLAlchemy format)
# Set this to use Postgres. Leave blank to use in-memory storage.
DATABASE_URL=postgresql+psycopg2://taskuser:taskpass@localhost:5432/tasks

# Redis (stretch goal - W4)
REDIS_URL=redis://localhost:6379/0
